{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jaxabstract",
  "version": "0.1.0",
  "identifier": "app.jaxabstract",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "jaxabstract",
        "url": "output.html",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Jaxabstract live output host"
  }
}
